{
	"name": "zone-wars",
	"version": "1.3.7",
	"scripts": {
		"dev": "concurrently \"pnpm watch\" \"pnpm serve\"",
		"lint": "eslint src && prettier --check src",
		"lint:fix": "eslint src --fix && prettier --write src",
		"watch": "rbxtsc -w",
		"serve": "rojo serve",
		"compile-game": "rbxtsc --verbose",
		"build-game": "rm -rf out && pnpm compile-game && rojo build --output Game.rbxl",
		"deploy:dev": "pnpm build-game && mantle deploy --environment dev",
		"deploy:prod": "pnpm build-game && mantle deploy --environment prod",
		"output:dev": "mantle outputs --environment dev > mantle-output-dev.json",
		"output:prod": "mantle outputs --environment prod > mantle-output-prod.json",
		"github": "./actions-runner/run.sh",
		"models": "lune run get-models",
		"sync-assets": "asphalt sync cloud",
		"rbx_cookie": "rbx_cookie"
	},
	"devDependencies": {
		"@rbxts/compiler-types": "3.0.0-types.0",
		"@rbxts/types": "^1.0.909",
		"@typescript-eslint/eslint-plugin": "^8.8.1",
		"@typescript-eslint/parser": "^8.8.1",
		"cross-env": "^7.0.3",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.2.1",
		"eslint-plugin-roblox-ts": "^0.0.36",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"eslint-plugin-unused-imports": "^4.1.4",
		"prettier": "^3.3.3",
		"rbxts-transform-env": "^3.0.0",
		"roblox-ts": "3.0.0",
		"typescript": "^5.6.2"
	},
	"dependencies": {
		"@rbxts-ui/alerts": "6.0.0",
		"@rbxts-ui/components": "7.0.1",
		"@rbxts-ui/layout": "6.0.2",
		"@rbxts-ui/primitives": "2.4.1",
		"@rbxts-ui/rem": "2.3.1",
		"@rbxts-ui/theme": "1.3.1",
		"@rbxts-ui/utils": "2.3.1",
		"@rbxts/beacon": "^2.1.1",
		"@rbxts/bitbuffer2": "1.0.0-ts.0",
		"@rbxts/falldown": "^1.0.3",
		"@rbxts/flipper": "^2.0.1",
		"@rbxts/lapis": "^0.3.6",
		"@rbxts/object-utils": "^1.0.4",
		"@rbxts/pretty-react-hooks": "^0.6.0",
		"@rbxts/react": "^17.2.1",
		"@rbxts/react-reflex": "^0.3.4",
		"@rbxts/react-roblox": "^17.2.1",
		"@rbxts/reflex": "^4.3.1",
		"@rbxts/remo": "^1.5.0",
		"@rbxts/ripple": "^0.9.1",
		"@rbxts/services": "^1.5.5",
		"@rbxts/set-timeout": "^1.1.2",
		"@rbxts/t": "^3.1.1",
		"@rbxts/testez": "0.4.2-ts.0",
		"@rbxts/ui-labs": "2.4.1",
		"@rbxts/validate-tree": "^2.0.2",
		"@rbxts/wait-for": "^0.1.5",
		"concurrently": "^9.1.2"
	},
	"packageManager": "pnpm@9.4.0"
}